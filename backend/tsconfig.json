{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    
    "ignoreDeprecations": "6.0"
  }
}